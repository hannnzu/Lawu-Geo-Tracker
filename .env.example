# Environment variables untuk Lawu Geo-Tracker
# Salin file ini ke .env dan isi nilai yang sesuai
# JANGAN commit file .env ke Git!

# === Parameter Pipeline Cuaca Historis (Open-Meteo) ===
# Open-Meteo Archive API gratis dan tidak membutuhkan API Key.
# Granularitas: hourly (per jam) -- 24 titik waktu per hari.
# Default: 5 tahun (2021-2025) = ~831.600 baris total
WEATHER_START_DATE=2021-01-01
WEATHER_END_DATE=2025-12-31

# === NASA FIRMS -- Data Kebakaran Hutan ===
# Fire Information for Resource Management System (NASA)
# Daftar MAP_KEY gratis di: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Langkah: buka URL -> klik "Get MAP Key" -> masukkan email -> cek inbox
# MAP_KEY terdiri dari 32 karakter alfanumerik
FIRMS_MAP_KEY=your_32_character_key_here
FIRMS_START_DATE=2021-01-01
FIRMS_END_DATE=2025-12-31
